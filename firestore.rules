rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════════
    //  Helper Functions
    // ═══════════════════════════════════════════════════════════════

    // Check if the requesting user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Get the user's profile document from the 'users' collection.
    // User docs are stored with auth UID as the document ID.
    function getUserProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Check if the user has an Admin or Department Head role.
    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        getUserProfile().role in ['Admin', 'Department Head'];
    }

    // ═══════════════════════════════════════════════════════════════
    //  Collection Rules
    // ═══════════════════════════════════════════════════════════════

    // --- META (settings, seed version) ---
    match /meta/{docId} {
      allow read: if isAuthenticated();
      // seedVersion must be writable by any authenticated user for
      // the client-side data seeding to work on first load.
      // All other meta docs (settings, etc.) are admin-only.
      allow write: if isAuthenticated() && docId == 'seedVersion';
      allow write: if isAdmin();
    }

    // --- USERS ---
    match /users/{userId} {
      // Any authenticated user can read user profiles (needed for login flow)
      allow read: if isAuthenticated();

      // Users can create their own profile (sign-up flow) — doc ID must match auth UID
      allow create: if isAuthenticated() && userId == request.auth.uid;

      // Users can update their own profile
      allow update: if isAuthenticated() && userId == request.auth.uid;

      // Admins can create, update, and delete any user profile
      allow create, update, delete: if isAdmin();
    }

    // --- ROOMS ---
    match /rooms/{roomId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // --- PROFESSORS (Faculty) ---
    match /professors/{profId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // --- SUBJECTS ---
    match /subjects/{subjectId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // --- SECTIONS ---
    match /sections/{sectionId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // --- SCHEDULES ---
    match /schedules/{scheduleId} {
      // All authenticated users can read schedules (students view them)
      allow read: if isAuthenticated();

      // Only admins can create, update, or delete schedules
      allow create, update, delete: if isAdmin();
    }

    // --- SCHEDULE HISTORY ---
    match /scheduleHistory/{historyId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      // History entries should not be modified or deleted
      allow update, delete: if false;
    }

    // --- DEPARTMENTS ---
    match /departments/{deptId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // --- COURSES ---
    match /courses/{courseId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // --- TRASH (Recycle Bin) ---
    match /trash/{trashId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // --- ACTIVITY LOGS ---
    match /activityLogs/{logId} {
      allow read: if isAdmin();
      // Any authenticated user can create log entries (login/view events)
      allow create: if isAuthenticated();
      // Logs should not be modified or deleted
      allow update, delete: if false;
    }

    // --- DEFAULT DENY ---
    // Any collection not explicitly matched above is denied
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
